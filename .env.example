# Copy to .env.local for local dev. In Amplify / hosting, set the same REACT_APP_* vars for builds.

# Lambda Function URL origin only (no trailing slash). Auth type must be NONE on the Function URL.
REACT_APP_ADMIN_AUTH_URL=https://xxxxxxxx.lambda-url.us-east-1.on.aws

# Optional: public URL of locations-content.json if not default (bucket region / CloudFront).
# REACT_APP_LOCATIONS_CONTENT_URL=https://wild-child-cms.s3.us-east-1.amazonaws.com/locations-content.json

# Optional: public URL of about-content.json if not default.
# REACT_APP_ABOUT_CONTENT_URL=https://wild-child-cms.s3.us-east-1.amazonaws.com/about-content.json

# Optional: public URL of media-content.json if not default.
# REACT_APP_MEDIA_CONTENT_URL=https://wild-child-cms.s3.us-east-1.amazonaws.com/media-content.json

# Optional: public URL of bridal-content.json if not default.
# REACT_APP_BRIDAL_CONTENT_URL=https://wild-child-cms.s3.us-east-1.amazonaws.com/bridal-content.json

# Optional: public URL of pages-content.json if not default.
# REACT_APP_PAGES_CONTENT_URL=https://wild-child-cms.s3.us-east-1.amazonaws.com/pages-content.json
