b:["$","div",null,{"className":"page-container","children":[["$","h1",null,{"className":"page-title","children":"About Wild Child Fabrications | Hair & Makeup Artist"}],["$","p",null,{"className":"intro-text","children":"Hi, I’m Christalee—owner and lead artist of Wild Child Fabrications, a bridal hair and makeup artist serving Pittsburgh, Atlanta, and New Orleans. Known for refined artistry with an edge, I create clean, beautiful looks for weddings, television production, print, and special events."}],["$","p",null,{"className":"intro-text","style":{"marginTop":"1rem"},"children":"Here's what you can expect from us:"}],["$","div",null,{"className":"about-layout","children":[["$","div",null,{"className":"about-image-container","children":["$","img",null,{"src":"/_next/static/media/pink-brand-hairspray.368b2a13.png","alt":"ChristaLee Lema - Professional Hair and Makeup Artist","className":"about-image"}]}],["$","section",null,{"className":"section-card","children":[["$","div","0",{"className":"faq-item","children":[["$","h3",null,{"className":"feature-title-with-logo","children":[["$","img",null,{"src":"/_next/static/media/wcf-lips-logo.443457bf.png","alt":"","className":"lips-logo-bullet"}],"Where We Work"]}],["$","p",null,{"className":"body-text","children":"Based in Pittsburgh, with travel to Atlanta and New Orleans, Wild Child Fabrications provides on-location bridal hair and makeup services for weddings, photoshoots, and productions."}]]}],["$","div","1",{"className":"faq-item","children":[["$","h3",null,{"className":"feature-title-with-logo","children":[["$","img",null,{"src":"/_next/static/media/wcf-lips-logo.443457bf.png","alt":"","className":"lips-logo-bullet"}],"What We Do"]}],["$","p",null,{"className":"body-text","children":"We provide on-location hair and makeup for bridal, television, print, editorial, and special events. Known for refined artistry with an edge, our work is clean, polished, and built to last—whether you’re walking down the aisle or stepping in front of the camera. Every look is tailored to feel like you, just elevated."}]]}],["$","div","2",{"className":"faq-item","children":[["$","h3",null,{"className":"feature-title-with-logo","children":[["$","img",null,{"src":"/_next/static/media/wcf-lips-logo.443457bf.png","alt":"","className":"lips-logo-bullet"}],"Expert Artists & Continuous Improvement"]}],["$","p",null,{"className":"body-text","children":"Whether it's just myself on your project or our team of artists, you can expect skilled and professional stylists. We regularly educate ourselves in all areas - including, but not limited to our artistry skills, communication, sanitation, and beauty products/trends."}]]}],["$","div","3",{"className":"faq-item","children":[["$","h3",null,{"className":"feature-title-with-logo","children":[["$","img",null,{"src":"/_next/static/media/wcf-lips-logo.443457bf.png","alt":"","className":"lips-logo-bullet"}],"Transparent Pricing"]}],["$","p",null,{"className":"body-text","children":"Whether it's for your wedding, a special event, or an television production project - we'll make sure you've seen and approved the pricing before it goes on your event contract."}]]}],["$","div","4",{"className":"faq-item","children":[["$","h3",null,{"className":"feature-title-with-logo","children":[["$","img",null,{"src":"/_next/static/media/wcf-lips-logo.443457bf.png","alt":"","className":"lips-logo-bullet"}],"Inclusive & Affirming Services"]}],["$","p",null,{"className":"body-text","children":"Our company is committed to creating an inclusive, affirming space where every client feels seen and celebrated. We proudly offer LGBTQ+ friendly hair and makeup services for all couples, genders, identities, and expressions—always listening first and tailoring each look to feel true to you."}]]}],["$","div","5",{"className":"faq-item","children":[["$","h3",null,{"className":"feature-title-with-logo","children":["$L15","Personalized Support"]}],"$L16"]}],"$L17"]}]]}]]}]
f:{"metadata":[["$","title","0",{"children":"About Christalee | Bridal & Film Makeup Artist in Pittsburgh, Atlanta & New Orleans"}],["$","meta","1",{"name":"description","content":"Meet Christalee of Wild Child Fabrications, a hair and makeup artist specializing in bridal, film & TV, and high-profile clients including celebrities and politicians in Pittsburgh, Atlanta, and New Orleans."}],["$","link","2",{"rel":"canonical","href":"https://wildchild-makeup.com/about-hair-and-makeup-artist"}],["$","meta","3",{"property":"og:title","content":"About Christalee | Bridal & Film Makeup Artist in Pittsburgh, Atlanta & New Orleans"}],["$","meta","4",{"property":"og:description","content":"Meet Christalee of Wild Child Fabrications, a hair and makeup artist specializing in bridal, film & TV, and high-profile clients including celebrities and politicians in Pittsburgh, Atlanta, and New Orleans."}],["$","meta","5",{"property":"og:url","content":"https://wildchild-makeup.com/about-hair-and-makeup-artist"}],["$","meta","6",{"name":"twitter:card","content":"summary"}],["$","meta","7",{"name":"twitter:title","content":"About Christalee | Bridal & Film Makeup Artist in Pittsburgh, Atlanta & New Orleans"}],["$","meta","8",{"name":"twitter:description","content":"Meet Christalee of Wild Child Fabrications, a hair and makeup artist specializing in bridal, film & TV, and high-profile clients including celebrities and politicians in Pittsburgh, Atlanta, and New Orleans."}]],"error":null,"digest":"$undefined"}
