16:["$","p",null,{"className":"body-text","children":"We provide personalized, on-location support for weddings, photo or commercial shoots, and special events—keeping your hair and makeup experience seamless and stress-free from start to finish. You can expect prompt, professional, and friendly communication throughout the booking process and on your event day."}]
17:["$","div","6",{"className":"faq-item","children":[["$","h3",null,{"className":"feature-title-with-logo","children":[["$","img",null,{"src":"/_next/static/media/wcf-lips-logo.443457bf.png","alt":"","className":"lips-logo-bullet"}],"On-Location Hair & Makeup Team"]}],["$","p",null,{"className":"body-text","children":"Our team is based across Pittsburgh, Atlanta, and New Orleans, allowing us to provide seamless on-location hair and makeup services for weddings, television, print, and special events in each city. We are a proudly inclusive, LGBTQ+ friendly team, creating a welcoming and affirming experience for all clients, couples, identities, and expressions."}]]}]
